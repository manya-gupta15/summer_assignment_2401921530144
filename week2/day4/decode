class Solution {
public:
    string decodeString(string s) {
        stack<int> counts;
        stack<string> strings;

        int currNum = 0;
        string currString = "";

        for (char ch : s) {

            if (isdigit(ch)) {
                currNum = currNum * 10 + (ch - '0');
            }

            else if (ch == '[') {
                counts.push(currNum);
                strings.push(currString);

                currNum = 0;
                currString = "";
            }

            else if (ch == ']') {
                int repeat = counts.top();
                counts.pop();

                string prevString = strings.top();
                strings.pop();

                string temp = "";

                for (int i = 0; i < repeat; i++) {
                    temp += currString;
                }

                currString = prevString + temp;
            }

            else {
                currString += ch;
            }
        }

        return currString;
    }
};
