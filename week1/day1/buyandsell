class Solution {
public:
    int maxProfit(vector<int>& prices) {
        int maxprofit = 0, minp = prices[0];
        for(int i=0;i<prices.size();i++)
        {
            int profit = prices[i]-minp;
          
            minp = min(minp, prices[i]);
            maxprofit = max( profit , maxprofit);
        }
        return maxprofit    ;
    }
};
