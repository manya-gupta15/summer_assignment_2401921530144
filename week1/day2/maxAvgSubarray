class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        long long sum = 0;
        for(int i=0;i<k;i++)
        {
            sum = sum+nums[i];
        }
        long long maxsum = sum;
        for(int i=k;i<nums.size();i++)
        {
            sum = sum+nums[i];
            sum = sum - nums[i-k];
            maxsum = max(maxsum, sum);
        }
        return(double) maxsum/k;
    }
};
